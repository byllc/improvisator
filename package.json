{
  "name": "@improvisator/monorepo",
  "version": "0.1.0",
  "description": "Improvisator - Progressive web app for improv comedy practice",
  "private": true,
  "workspaces": [
    "core",
    "web",
    "mobile"
  ],
  "scripts": {
    "build": "npm run build -ws",
    "build:core": "npm run build -w core",
    "build:web": "npm run build:core && npm run build -w web",
    "build:all": "npm run build:core && npm run build -w web",
    "dev": "npm run dev -w web",
    "test": "npm run test -ws",
    "test:watch": "npm run test:watch -w core && npm run test:watch -w web",
    "test:coverage": "npm run test:coverage -ws",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css}\""
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-react": "^7.32.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "prettier": "^3.0.0"
  }
}
